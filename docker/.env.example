# 复制本文件为 `docker/.env` 后按需修改（不要将含真实密码的 `.env` 提交到 Git）。

# 与 stockManager 等同机部署时必设，避免 Compose 项目名冲突（backend/frontend 服务名相同）
COMPOSE_PROJECT_NAME=carsales

# --- MySQL（mysql 服务）---
MYSQL_ROOT_PASSWORD=change_me_root
DB_NAME=car_sales
DB_USER=car_sales
DB_PASSWORD=change_me_app

# 说明：官方镜像不允许 MYSQL_USER=root；应用应使用 DB_USER / DB_PASSWORD 对应 MYSQL_USER / MYSQL_PASSWORD。

# --- 宿主机端口映射（可选）---
BACKEND_PUBLISH_PORT=8001
FRONTEND_PUBLISH_PORT=8081

# --- 前端构建（写入 frontend 镜像，改后须 docker compose build frontend）---
# 注意：backend/.env 仅本地直跑后端用，Compose 不会读取。
VITE_GLOB_API_URL=/api
VITE_APP_TITLE=中国市场汽车销量
VITE_APP_NAMESPACE=vben-web-tdesign
VITE_APP_STORE_SECURE_KEY=please-replace-me-with-your-own-key
VITE_ADMIN_REFRESH_CONFIRM_CODE=change-me

# --- Gunicorn（可选，写入 backend 容器环境变量）---
# GUNICORN_WORKERS=2
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info
