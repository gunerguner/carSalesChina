VITE_BASE=/

# 应用标题（Docker 构建由 docker/.env 的 VITE_APP_TITLE 覆盖）
VITE_APP_TITLE=中国市场汽车销量

# 接口地址（Docker 部署由 docker/.env 的 build-arg 覆盖；本地生产构建默认同源 /api）
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成 dist.zip（Docker/CI 不需要，保持 false 以加快构建）
VITE_ARCHIVER=false
