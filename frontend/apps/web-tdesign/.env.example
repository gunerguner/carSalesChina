# 应用标题
VITE_APP_TITLE=中国市场汽车销量

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
VITE_APP_NAMESPACE=vben-web-tdesign

# 对store进行加密的密钥
VITE_APP_STORE_SECURE_KEY=please-replace-me-with-your-own-key

# 端口号
VITE_PORT=5999

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否开启 PWA（carSales 默认关闭）
VITE_PWA=false

# 打包后是否生成 dist.zip（Docker 只需 dist/，建议 false）
VITE_ARCHIVER=false

# 开发态 Vue DevTools 插件（关闭可加快 dev 冷启动）
VITE_DEVTOOLS=false
